# Daily Databricks Feed - Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control

# =============================================================================
# Reddit API (https://www.reddit.com/prefs/apps)
# Create a "script" type application to get these credentials
# =============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# =============================================================================
# YouTube Data API v3 (https://console.cloud.google.com/apis/credentials)
# Enable "YouTube Data API v3" and create an API key
# =============================================================================
YOUTUBE_API_KEY=

# =============================================================================
# Google Cloud Platform (for TTS and GCS)
# Create a service account with roles:
#   - Cloud Text-to-Speech API User
#   - Storage Object Admin (for your bucket)
# Download the JSON key and paste the ENTIRE content below (single line)
# =============================================================================
GCP_SERVICE_ACCOUNT_JSON=

# =============================================================================
# Google Cloud Storage Configuration
# Create a bucket for hosting audio files and RSS feed
# Make sure the bucket allows public read access for the podcast files
# =============================================================================
GCS_BUCKET_NAME=your-podcast-bucket
AUDIO_BASE_URL=https://storage.googleapis.com/your-podcast-bucket

# =============================================================================
# LLM API Keys (at least one recommended for script generation)
# =============================================================================

# Groq (Recommended - Fast & Free)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic Claude (Optional)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (Optional)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# =============================================================================
# Pipeline Configuration (Optional)
# =============================================================================

# Number of days to look back for news (default: 1)
DAYS_BACK=1

# Maximum stories to include in podcast (default: 10)
MAX_STORIES=10

# Podcast metadata
PODCAST_NAME=Daily Databricks Digest
PODCAST_AUTHOR=Daily Databricks Team
PODCAST_EMAIL=podcast@example.com

# Enable mock TTS for testing without GCP (default: false)
USE_MOCK_TTS=false

# Skip uploads for testing (default: false)
DRY_RUN=false
